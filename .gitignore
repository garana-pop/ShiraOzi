# =================================================================
# Unity .gitignore Template (既存の設定)
# =================================================================
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
*.log
*.blend1
*.blend1.meta
/[Mm]emoryCaptures/
/[Rr]ecordings/
.vs/
.gradle/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
sysinfo.txt
mono_crash.*
*.apk
*.aab
*.unitypackage
*.app

# =================================================================
# 強力な制限設定 (今回の要件)
# =================================================================

# 1. まずAssets内のすべてのファイルを無視する
/Assets/**/*

# 2. Assets内のディレクトリ構造をたどれるように、ディレクトリ自体は無視しない
!/Assets/**/

# 3. 指定されたフォルダ内の特定拡張子のみを例外として許可する
!/Assets/Editor/**/*.cs
!/Assets/Scripts/**/*.cs
!/Assets/Plans/**/*.md
!/Assets/Project_Overview.md

# 4. Unityで必須となる .meta ファイルも(上記フォルダ内のみ)許可する
# ※これがないとUnity上でインポート設定が保持されません
!/Assets/Editor/**/*.meta
!/Assets/Scripts/**/*.meta
!/Assets/Plans/**/*.meta
!/Assets/Project_Overview.md.meta